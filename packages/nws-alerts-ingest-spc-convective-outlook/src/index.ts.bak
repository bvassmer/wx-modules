import moment from "moment-timezone";
import type { Feature, FeatureCollection, Position } from "geojson";
import {
  booleanPointInPolygon,
  featureCollection,
  featureEach,
  point,
  polygon,
} from "@turf/turf";
// @ts-ignore - jsdom does not have type definitions in this project
import { JSDOM } from "jsdom";
// @ts-ignore - jquery does not have type definitions in this project
import jquery from "jquery";
import {
  Alert,
  IngestionConfig,
  IngestionResult,
  defaultLogger,
  resolveFetch,
  resolveNow,
} from "nws-alerts-ingest-core";

const SPC_CONV_DAY_12_OUTLOOK_TYPE = {
  CATEGORICAL: "cat",
  TORNADO: "torn",
  SIGNIFICANT_TORNADO: "sigtorn",
  HAIL: "hail",
  SIGNIFICANT_HAIL: "sighail",
  WIND: "wind",
  SIGNIFICANT_WIND: "sigwind",
  HTML: "html",
};
const SPC_CONV_DAY_3_OUTLOOK_TYPE = {
  CATEGORICAL: "cat",
  PROB: "prob",
  SIGNIFICANT_PROB: "sigprob",
  HTML: "html",
};

const SPC_RISKS = {
  TWO_PERCENT: "0.02",
  FIVE_PERCENT: "0.05",
  TEN_PERCENT: "0.10",
  FIFTEEN_PERCENT: "0.15",
  THIRTY_PERCENT: "0.30",
  FOURTY_FIVE_PERCENT: "0.45",
  SIXTY_PERCENT: "0.60",
  SIGN: "SIGN",
  THUNDERSTORM: "TSTM",
  MARGINAL: "MRGL",
  SLIGHT: "SLGT",
  ENHANCED: "ENH",
  MODERATE: "MDT",
  HIGH: "HIGH",
};

type SPC_CONV_OUTLOOK_DAY_12 = {
  cat?: string;
  torn?: string;
  hail?: string;
  wind?: string;
  sigtorn?: string;
  sighail?: string;
  sigwind?: string;
  html?: string;
};

type SPC_CONV_OUTLOOK_DAY_3 = {
  cat?: string;
  prob?: string;
  sigprob?: string;
  html?: string;
};

type SPC_CONV_OUTLOOK_DAY_45678 = {
  prob?: string;
  html?: string;
};

type SPC_CONV_OUTLOOK_DAY_12_FEATURES = {
  cat?: FeatureCollection;
  torn?: FeatureCollection;
  hail?: FeatureCollection;
  wind?: FeatureCollection;
  sigtorn?: FeatureCollection;
  sighail?: FeatureCollection;
  sigwind?: FeatureCollection;
  html?: string;
};

type SPC_CONV_OUTLOOK_DAY_3_FEATURES = {
  cat?: FeatureCollection;
  prob?: FeatureCollection;
  sigprob?: FeatureCollection;
  html?: string;
};

type SPC_CONV_OUTLOOK_DAY_45678_FEATURES = {
  prob?: FeatureCollection;
  html?: string;
};

const generateOutlookSearchTimes = () => {
  return {
    "0100": {
      START: moment().tz("America/Chicago").utc().hour(0).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(2).startOf("hour"),
    },
    "0600": {
      START: moment().tz("America/Chicago").utc().hour(5).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(7).startOf("hour"),
    },
    "0730": {
      START: moment().tz("America/Chicago").utc().hour(6).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(8).startOf("hour"),
    },
    "0900": {
      START: moment().tz("America/Chicago").utc().hour(8).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(10).startOf("hour"),
    },
    "1200": {
      START: moment().tz("America/Chicago").utc().hour(11).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(13).startOf("hour"),
    },
    "1300": {
      START: moment().tz("America/Chicago").utc().hour(12).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(14).startOf("hour"),
    },
    "1630": {
      START: moment().tz("America/Chicago").utc().hour(15).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(17).startOf("hour"),
    },
    "1730": {
      START: moment().tz("America/Chicago").utc().hour(16).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(18).startOf("hour"),
    },
    "1930": {
      START: moment().tz("America/Chicago").utc().hour(19).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(21).startOf("hour"),
    },
    "2000": {
      START: moment().tz("America/Chicago").utc().hour(19).startOf("hour"),
      END: moment().tz("America/Chicago").utc().hour(21).startOf("hour"),
    },
  };
};

const getSpcConvDay123GeoJsonUrl = ({
  day,
  time,
  type,
}: {
  day: number;
  time: string;
  type: string;
}) => {
  if (time === "0100") {
    return `https://www.spc.noaa.gov/products/outlook/archive/${moment()
      .tz("America/Chicago")
      .add(1, "day")
      .format("YYYY")}/day${day}otlk_${moment()
      .tz("America/Chicago")
      .add(1, "day")
      .format("YYYYMMDD")}_${time}_${type}.lyr.geojson`;
  }
  return `https://www.spc.noaa.gov/products/outlook/archive/${moment()
    .tz("America/Chicago")
    .format("YYYY")}/day${day}otlk_${moment()
    .tz("America/Chicago")
    .format("YYYYMMDD")}_${time}_${type}.lyr.geojson`;
};

const getSpcConvDay45678GeoJsonUrl = ({ day }: { day: number }) => {
  return `https://www.spc.noaa.gov/products/exper/day4-8/archive/${moment()
    .tz("America/Chicago")
    .format("YYYY")}/day${day}prob_${moment()
    .tz("America/Chicago")
    .format("YYYYMMDD")}.lyr.geojson`;
};

const getSpcConvDay123HtmlUrl = ({
  day,
  time,
}: {
  day: number;
  time: string;
}) => {
  if (time === "0100") {
    return `https://www.spc.noaa.gov/products/outlook/archive/${moment()
      .tz("America/Chicago")
      .add(1, "day")
      .format("YYYY")}/day${day}otlk_${moment()
      .tz("America/Chicago")
      .add(1, "day")
      .format("YYYYMMDD")}_${time}.html`;
  }
  return `https://www.spc.noaa.gov/products/outlook/archive/${moment()
    .tz("America/Chicago")
    .format("YYYY")}/day${day}otlk_${moment()
    .tz("America/Chicago")
    .format("YYYYMMDD")}_${time}.html`;
};

const getSpcConvDay45678HtmlUrl = () => {
  return `https://www.spc.noaa.gov/products/exper/day4-8/archive/${moment()
    .tz("America/Chicago")
    .format("YYYY")}/day4-8_${moment()
    .tz("America/Chicago")
    .format("YYYYMMDD")}.html`;
};

const getConvOutlookDay1Urls = (
  now: moment.Moment,
): SPC_CONV_OUTLOOK_DAY_12 | undefined => {
  const outputSearchTimes = generateOutlookSearchTimes();
  let spcDay1Time: string | undefined;

  if (
    now.isBetween(
      outputSearchTimes["1200"].START,
      outputSearchTimes["1200"].END,
    )
  ) {
    spcDay1Time = "1200";
  }
  if (
    now.isBetween(
      outputSearchTimes["1300"].START,
      outputSearchTimes["1300"].END,
    )
  ) {
    spcDay1Time = "1300";
  }
  if (
    now.isBetween(
      outputSearchTimes["1630"].START,
      outputSearchTimes["1630"].END,
    )
  ) {
    spcDay1Time = "1630";
  }
  if (
    now.isBetween(
      outputSearchTimes["2000"].START,
      outputSearchTimes["2000"].END,
    )
  ) {
    spcDay1Time = "2000";
  }
  if (
    now.isBetween(
      outputSearchTimes["0100"].START,
      outputSearchTimes["0100"].END,
    )
  ) {
    spcDay1Time = "0100";
  }

  if (!spcDay1Time) {
    return undefined;
  }

  const urls: SPC_CONV_OUTLOOK_DAY_12 = {};
  Object.values(SPC_CONV_DAY_12_OUTLOOK_TYPE).forEach((type: string) => {
    urls[type as keyof SPC_CONV_OUTLOOK_DAY_12] = getSpcConvDay123GeoJsonUrl({
      day: 1,
      time: spcDay1Time,
      type,
    });
  });
  urls.html = getSpcConvDay123HtmlUrl({ day: 1, time: spcDay1Time });
  return urls;
};

const getConvOutlookDay2Urls = (
  now: moment.Moment,
): SPC_CONV_OUTLOOK_DAY_12 | undefined => {
  const outputSearchTimes = generateOutlookSearchTimes();
  let spcDay2Time: string | undefined;
  if (
    now.isBetween(
      outputSearchTimes["0600"].START,
      outputSearchTimes["0600"].END,
    )
  ) {
    spcDay2Time = "0600";
  }
  if (
    now.isBetween(
      outputSearchTimes["1730"].START,
      outputSearchTimes["1730"].END,
    )
  ) {
    spcDay2Time = "1730";
  }
  if (!spcDay2Time) {
    return undefined;
  }

  const urls: SPC_CONV_OUTLOOK_DAY_12 = {};
  Object.values(SPC_CONV_DAY_12_OUTLOOK_TYPE).forEach((type: string) => {
    urls[type as keyof SPC_CONV_OUTLOOK_DAY_12] = getSpcConvDay123GeoJsonUrl({
      day: 2,
      time: spcDay2Time,
      type,
    });
  });
  urls.html = getSpcConvDay123HtmlUrl({ day: 2, time: spcDay2Time });
  return urls;
};

const getConvOutlookDay3Urls = (
  now: moment.Moment,
): SPC_CONV_OUTLOOK_DAY_3 | undefined => {
  const outputSearchTimes = generateOutlookSearchTimes();
  let spcDay3Time: string | undefined;
  if (
    now.isBetween(
      outputSearchTimes["0730"].START,
      outputSearchTimes["0730"].END,
    )
  ) {
    spcDay3Time = "0730";
  }
  if (
    now.isBetween(
      outputSearchTimes["1930"].START,
      outputSearchTimes["1930"].END,
    )
  ) {
    spcDay3Time = "1930";
  }
  if (!spcDay3Time) {
    return undefined;
  }

  const urls: SPC_CONV_OUTLOOK_DAY_3 = {};
  Object.values(SPC_CONV_DAY_3_OUTLOOK_TYPE).forEach((type: string) => {
    urls[type as keyof SPC_CONV_OUTLOOK_DAY_3] = getSpcConvDay123GeoJsonUrl({
      day: 3,
      time: spcDay3Time,
      type,
    });
