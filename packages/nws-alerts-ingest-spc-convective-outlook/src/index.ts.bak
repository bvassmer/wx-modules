  if (found[SPC_RISKS.SIXTY_PERCENT]) return SPC_RISKS.SIXTY_PERCENT;
  if (found[SPC_RISKS.FOURTY_FIVE_PERCENT])
    return SPC_RISKS.FOURTY_FIVE_PERCENT;
  if (found[SPC_RISKS.THIRTY_PERCENT]) return SPC_RISKS.THIRTY_PERCENT;
  if (found[SPC_RISKS.FIFTEEN_PERCENT]) return SPC_RISKS.FIFTEEN_PERCENT;
  if (found[SPC_RISKS.FIVE_PERCENT]) return SPC_RISKS.FIVE_PERCENT;
  return null;
};

const findHighestSigRisk = ({
  fc,
  lat,
  lon,
}: {
  fc: FeatureCollection;
  lat: number;
  lon: number;
}) => {
  const found = {
    [SPC_RISKS.SIGN]: false,
  };
  const myPoint = point([lon, lat]);
  featureEach(
    fc,
    (feature: Feature & { geometry: { coordinates: Position[][][] } }) => {
      if (feature?.geometry?.coordinates?.length) {
        const poly = polygon(feature.geometry.coordinates[0]);
        if (poly && booleanPointInPolygon(myPoint, poly)) {
          found[feature.properties?.LABEL] = true;
        }
      }
    },
  );

  if (found[SPC_RISKS.SIGN]) return SPC_RISKS.SIGN;
  return null;
};

export const ingest = async (
  config: IngestionConfig,
): Promise<IngestionResult<Record<string, unknown>>> => {
  const logger = config.logger ?? defaultLogger;
  const fetchImpl = resolveFetch(config);
  const now = moment(resolveNow(config)).tz("America/Chicago").utc();

  const day1Urls = getConvOutlookDay1Urls(now);
  const day2Urls = getConvOutlookDay2Urls(now);
  const day3Urls = getConvOutlookDay3Urls(now);
  const day4Urls = getConvOutlookDay45678Urls({ day: 4, now });
  const day5Urls = getConvOutlookDay45678Urls({ day: 5, now });
  const day6Urls = getConvOutlookDay45678Urls({ day: 6, now });
  const day7Urls = getConvOutlookDay45678Urls({ day: 7, now });
  const day8Urls = getConvOutlookDay45678Urls({ day: 8, now });

  const day1 = day1Urls
    ? {
        cat: await getUrlJson(fetchImpl, day1Urls.cat),
        hail: await getUrlJson(fetchImpl, day1Urls.hail),
        sighail: await getUrlJson(fetchImpl, day1Urls.sighail),
        wind: await getUrlJson(fetchImpl, day1Urls.wind),
        sigwind: await getUrlJson(fetchImpl, day1Urls.sigwind),
        torn: await getUrlJson(fetchImpl, day1Urls.torn),
        sigtorn: await getUrlJson(fetchImpl, day1Urls.sigtorn),
        html: fixRelativeLinksInSpcHtml(
          await getUrlText(fetchImpl, day1Urls.html),
        ),
      }
    : undefined;

  const day2 = day2Urls
    ? {
        cat: await getUrlJson(fetchImpl, day2Urls.cat),
        hail: await getUrlJson(fetchImpl, day2Urls.hail),
        sighail: await getUrlJson(fetchImpl, day2Urls.sighail),
        wind: await getUrlJson(fetchImpl, day2Urls.wind),
        sigwind: await getUrlJson(fetchImpl, day2Urls.sigwind),
        torn: await getUrlJson(fetchImpl, day2Urls.torn),
        sigtorn: await getUrlJson(fetchImpl, day2Urls.sigtorn),
        html: fixRelativeLinksInSpcHtml(
          await getUrlText(fetchImpl, day2Urls.html),
        ),
      }
    : undefined;

  const day3 = day3Urls
    ? {
        cat: await getUrlJson(fetchImpl, day3Urls.cat),
        prob: await getUrlJson(fetchImpl, day3Urls.prob),
        sigprob: await getUrlJson(fetchImpl, day3Urls.sigprob),
        html: fixRelativeLinksInSpcHtml(
          await getUrlText(fetchImpl, day3Urls.html),
        ),
      }
    : undefined;

  const day4 = day4Urls
    ? {
        prob: await getUrlJson(fetchImpl, day4Urls.prob),
        html: fixRelativeLinksInSpcDay45678Html(
          extractDay45678Table(await getUrlText(fetchImpl, day4Urls.html)),
        ),
      }
    : undefined;
  const day5 = day5Urls
    ? {
        prob: await getUrlJson(fetchImpl, day5Urls.prob),
        html: fixRelativeLinksInSpcDay45678Html(
          extractDay45678Table(await getUrlText(fetchImpl, day5Urls.html)),
        ),
      }
    : undefined;
  const day6 = day6Urls
    ? {
        prob: await getUrlJson(fetchImpl, day6Urls.prob),
        html: fixRelativeLinksInSpcDay45678Html(
          extractDay45678Table(await getUrlText(fetchImpl, day6Urls.html)),
        ),
      }
    : undefined;
  const day7 = day7Urls
    ? {
        prob: await getUrlJson(fetchImpl, day7Urls.prob),
        html: fixRelativeLinksInSpcDay45678Html(
          extractDay45678Table(await getUrlText(fetchImpl, day7Urls.html)),
        ),
      }
    : undefined;
  const day8 = day8Urls
    ? {
        prob: await getUrlJson(fetchImpl, day8Urls.prob),
        html: fixRelativeLinksInSpcDay45678Html(
          extractDay45678Table(await getUrlText(fetchImpl, day8Urls.html)),
        ),
      }
    : undefined;

  const alerts: Alert[] = [];

  const day1Levels = day1
    ? {
        cat: findHighestCatRisk({
          fc: day1.cat ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        torn: findHighestTornRisk({
          fc: day1.torn ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        hail: findHighestHailWindRisk({
          fc: day1.hail ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        wind: findHighestHailWindRisk({
          fc: day1.wind ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        sigtorn: findHighestSigRisk({
          fc: day1.sigtorn ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        sighail: findHighestSigRisk({
          fc: day1.sighail ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        sigwind: findHighestSigRisk({
          fc: day1.sigwind ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
      }
    : undefined;

  if (day1?.html && day1Levels?.cat) {
    alerts.push({
      nwsId: day1Urls?.html ?? "spc-day1",
      event: "SPC Convective Outlook Day 1",
      headline: `SPC Conv Day 1 - ${day1Levels.cat} T${day1Levels.torn ?? ""}${
        day1Levels.sigtorn ? "*" : ""
      } H${day1Levels.hail ?? ""}${day1Levels.sighail ? "*" : ""} W${
        day1Levels.wind ?? ""
      }${day1Levels.sigwind ? "*" : ""}`,
      description: day1.html,
      sent: new Date(now.toISOString()),
      source: "spc-convective-outlook",
      extra: {
        day: 1,
        levels: day1Levels,
        urls: day1Urls,
      },
    });
  }

  const day2Levels = day2
    ? {
        cat: findHighestCatRisk({
          fc: day2.cat ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        torn: findHighestTornRisk({
          fc: day2.torn ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        hail: findHighestHailWindRisk({
          fc: day2.hail ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        wind: findHighestHailWindRisk({
          fc: day2.wind ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        sigtorn: findHighestSigRisk({
          fc: day2.sigtorn ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        sighail: findHighestSigRisk({
          fc: day2.sighail ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        sigwind: findHighestSigRisk({
          fc: day2.sigwind ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
      }
    : undefined;

  if (day2?.html && day2Levels?.cat) {
    alerts.push({
      nwsId: day2Urls?.html ?? "spc-day2",
      event: "SPC Convective Outlook Day 2",
      headline: `SPC Conv Day 2 - ${day2Levels.cat} T${day2Levels.torn ?? ""}${
        day2Levels.sigtorn ? "*" : ""
      } H${day2Levels.hail ?? ""}${day2Levels.sighail ? "*" : ""} W${
        day2Levels.wind ?? ""
      }${day2Levels.sigwind ? "*" : ""}`,
      description: day2.html,
      sent: new Date(now.toISOString()),
      source: "spc-convective-outlook",
      extra: {
        day: 2,
        levels: day2Levels,
        urls: day2Urls,
      },
    });
  }

  const day3Levels = day3
    ? {
        cat: findHighestCatRisk({
          fc: day3.cat ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        prob: findHighestHailWindRisk({
          fc: day3.prob ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
        sigprob: findHighestSigRisk({
          fc: day3.sigprob ?? featureCollection([]),
          lat: config.lat,
          lon: config.lon,
        }),
      }
    : undefined;

  if (day3?.html && day3Levels?.cat) {
    alerts.push({
      nwsId: day3Urls?.html ?? "spc-day3",
      event: "SPC Convective Outlook Day 3",
      headline: `SPC Conv Day 3 - ${day3Levels.cat} P${day3Levels.prob ?? ""}${
        day3Levels.sigprob ? "*" : ""
      }`,
      description: day3.html,
      sent: new Date(now.toISOString()),
      source: "spc-convective-outlook",
      extra: {
        day: 3,
        levels: day3Levels,
        urls: day3Urls,
      },
    });
  }

  const day45678Levels = async (
    dayNum: number,
    data?: SPC_CONV_OUTLOOK_DAY_45678_FEATURES,
    urls?: SPC_CONV_OUTLOOK_DAY_45678,
  ) => {
    if (!data?.html) return;
    const prob = findHighestHailWindRisk({
      fc: data.prob ?? featureCollection([]),
      lat: config.lat,
      lon: config.lon,
    });
    if (!prob) return;
    alerts.push({
      nwsId: urls?.html ?? `spc-day${dayNum}`,
      event: `SPC Convective Outlook Day ${dayNum}`,
      headline: `SPC Conv Day ${dayNum} - P${prob}`,
      description: data.html,
      sent: new Date(now.toISOString()),
      source: "spc-convective-outlook",
      extra: {
        day: dayNum,
        levels: { prob },
        urls,
      },
    });
  };

  await day45678Levels(4, day4, day4Urls);
  await day45678Levels(5, day5, day5Urls);
  await day45678Levels(6, day6, day6Urls);
  await day45678Levels(7, day7, day7Urls);
  await day45678Levels(8, day8, day8Urls);

  logger.info("spc-convective-outlook:alerts", { count: alerts.length });

  return {
    alerts,
    raw: {
      day1,
      day2,
      day3,
      day4,
      day5,
      day6,
      day7,
      day8,
    },
    meta: {
      issuedAt: now.toISOString(),
    },
    dedupeKeys: alerts.map((alert) => alert.nwsId),
  };
};
